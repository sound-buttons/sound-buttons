{
  "name": "sound-buttons",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start_ssl": "ng serve --ssl",
    "worker_deploy": "wrangler deploy worker/worker.js --name sound-buttons --compatibility-date 2022-10-15",
    "i18n:extract": "ngx-translate-extract --input ./src --output ./src/assets/i18n/ja.json --clean --format json",
    "config": "ts-node -O '{\"module\": \"commonjs\"}' ./write-production-config.ts",
    "build": "npm run config && ng build --configuration production",
    "start": "ng serve",
    "test": "ng test",
    "test:ci": "ng test --watch=false --code-coverage --browsers=ChromeHeadlessNoSandbox",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.15",
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "mime": "^4.1.0",
    "ngx-bootstrap": "^21.2.0",
    "ngx-toastr": "^20.0.5",
    "random": "^5.4.1",
    "rxjs": "~7.8.2",
    "tocbot": "^4.36.8",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.13",
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^21.4.0",
    "@angular/cli": "^21.2.13",
    "@types/gtag.js": "^0.0.20",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "typescript-eslint": "^8.60.0",
    "@vendure/ngx-translate-extract": "^10.1.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "^6.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
